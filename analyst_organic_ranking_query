Final AS (
  SELECT * FROM TexasState WHERE Page IS NOT NULL
  UNION ALL
  SELECT * FROM CitySpecific WHERE Page IS NOT NULL
  UNION ALL
  SELECT * FROM P2C WHERE Page IS NOT NULL
  UNION ALL
  SELECT * FROM BestProviders WHERE Page IS NOT NULL
  UNION ALL
  SELECT * FROM NoDeposit WHERE Page IS NOT NULL
)

SELECT
  AVG_TRUE_RANK,
  AVG_WEB_RANK,
  CASE
    WHEN organic_results_link = 'https://www.choosetexaspower.org/' THEN 'CTXP Homepage'
    WHEN organic_results_link = 'https://www.choosetexaspower.org/electricity-rates/' THEN 'CTXP Texas'
    WHEN organic_results_link = 'https://www.choosetexaspower.org/electricity-rates/houston/' THEN 'CTXP Houston'
    WHEN organic_results_link = 'https://www.choosetexaspower.org/electricity-rates/dallas/' THEN 'CTXP Dallas'
    WHEN organic_results_link = 'https://www.choosetexaspower.org/electricity-rates/fort-worth/' THEN 'CTXP Fort Worth'
    WHEN organic_results_link = 'https://www.choosetexaspower.org/electricity-providers/' THEN 'CTXP Best Providers'
    WHEN organic_results_link = 'https://www.chooseenergy.com/electricity-rates/texas/' THEN 'Choose Texas'
    WHEN organic_results_link = 'https://www.chooseenergy.com/electricity-rates/texas/houston/' THEN 'Choose Houston'
    WHEN organic_results_link = 'https://www.chooseenergy.com/electricity-rates/texas/dallas/' THEN 'Choose Dallas'
    WHEN organic_results_link = 'https://www.saveonenergy.com/electricity-rates/texas/' THEN 'SOE Texas'
    WHEN organic_results_link = 'https://www.saveonenergy.com/electricity-rates/texas/houston/' THEN 'SOE Houston'
