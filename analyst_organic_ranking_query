WITH TexasState AS (
  SELECT
    ROUND(AVG(organic_results_true_rank), 2) AS AVG_TRUE_RANK,
    ROUND(AVG(organic_results_web_rank), 2) AS AVG_WEB_RANK,
    organic_results_link,
    date,
    'Texas' AS page,
    organic_results_link_domain AS Website,
    SUM(avg_search_volume) AS SearchVolume,
    COUNT(DISTINCT CASE WHEN organic_results_web_rank <= 10 THEN keyword_tracked END) AS KeywordsInTop10,
    ROUND(
      SUM(
        organic_results_web_rank * CASE
          WHEN avg_search_volume = 99 THEN 0
          ELSE avg_search_volume
        END
      ) * 1.0
      / NULLIF(
        SUM(
          CASE
            WHEN avg_search_volume = 99 THEN 0
            ELSE avg_search_volume
          END
        ),
        0
      ),
      2
    ) AS weighted_average_rank
  FROM lakehouse_production.common.seo_fact_clarity_keywords_rankings_json
  WHERE keyword_tags ILIKE '%SoV_Texas_State%'
    AND date >= '2025-12-01'
    AND organic_results_link IN (
      'https://www.chooseenergy.com/electricity-rates/texas/',
      'https://www.saveonenergy.com/electricity-rates/texas/',
      'https://www.choosetexaspower.org/electricity-rates/'
    )
    AND organic_results_link NOT ILIKE '%staging%'
    AND device = 'mobile'
    AND organic_results_link NOT ILIKE '%2%'
    AND location_requested IN (
      'Houston, TX, USA',
      'Arlington, TX, USA',
      'Dallas, TX, USA',
      'Corpus Christi, TX, USA',
      'Fort Worth, TX, USA',
      'Plano, TX',
      'Lubbock, TX, USA'
    )
    AND keyword_tracked IN (
      'electric rates texas',
      'electricity rates in texas',
      'texas energy rates',
      'texas electricity rates',
      'energy rates texas',
      'energy rates in texas',
      'cheapest electricity in texas',
      'cheap electricity texas',
      'cheap electricity in texas',
      'best electricity rates in texas',
      'best electric rates in texas',
      'best energy rates in texas',
      'cheapest electricity rates in texas',
      'lowest electric rates in texas',
      'best energy plans in texas',
      'who has the cheapest electricity rates in texas',
      'power plans',
      'cheap power'
    )
  GROUP BY 3, 4, 5, 6
),

CitySpecific AS (
  SELECT
    ROUND(AVG(organic_results_true_rank), 2) AS AVG_TRUE_RANK,
    ROUND(AVG(organic_results_web_rank), 2) AS AVG_WEB_RANK,
    organic_results_link,
    date,
    CASE
      WHEN keyword_tags ILIKE '%2.SoV_Dallas%'
        AND location_requested ILIKE '%Dallas%'
        AND organic_results_link IN (
          'https://www.chooseenergy.com/electricity-rates/texas/dallas/',
          'https://www.choosetexaspower.org/electricity-rates/dallas/'
        ) THEN 'Dallas'
      WHEN keyword_tags ILIKE '%2.SoV_Fort_Worth%'
        AND location_requested ILIKE '%Fort Worth%'
        AND organic_results_link = 'https://www.choosetexaspower.org/electricity-rates/fort-worth/' THEN 'Fort Worth'
      WHEN keyword_tags ILIKE '%2.SoV_Houston%'
        AND location_requested ILIKE '%Houston%'
        AND organic_results_link IN (
          'https://www.chooseenergy.com/electricity-rates/texas/houston/',
          'https://www.choosetexaspower.org/electricity-rates/houston/',
          'https://www.saveonenergy.com/electricity-rates/texas/houston/'
        ) THEN 'Houston'
    END AS Page,
    organic_results_link_domain AS Website,
    SUM(avg_search_volume) AS SearchVolume,
    COUNT(CASE WHEN organic_results_web_rank <= 10 THEN keyword_tracked END) AS KeywordsInTop10,
    ROUND(
      SUM(
        organic_results_web_rank * CASE
          WHEN avg_search_volume = 99 THEN 0
          ELSE avg_search_volume
        END
      ) * 1.0
      / NULLIF(
        SUM(
          CASE
            WHEN avg_search_volume = 99 THEN 0
            ELSE avg_search_volume
          END
        ),
        0
      ),
      2
    ) AS weighted_average_rank
  FROM lakehouse_production.common.seo_fact_clarity_keywords_rankings_json
  WHERE keyword_tags IS NOT NULL
    AND location_requested IS NOT NULL
    AND organic_results_link IS NOT NULL
    AND (
      (keyword_tags ILIKE '%2.SoV_Dallas%' AND location_requested ILIKE '%Dallas%')
      OR (keyword_tags ILIKE '%2.SoV_Fort_Worth%' AND location_requested ILIKE '%Fort Worth%')
      OR (keyword_tags ILIKE '%2.SoV_Houston%' AND location_requested ILIKE '%Houston%')
    )
    AND organic_results_link IN (
      'https://www.choosetexaspower.org/electricity-rates/houston/',
      'https://www.choosetexaspower.org/electricity-rates/dallas/',
      'https://www.choosetexaspower.org/electricity-rates/fort-worth/',
      'https://www.chooseenergy.com/electricity-rates/texas/houston/',
      'https://www.chooseenergy.com/electricity-rates/texas/dallas/',
      'https://www.saveonenergy.com/electricity-rates/texas/houston/'
    )
    AND device = 'mobile'
    AND date >= '2025-12-01'
  GROUP BY 3, 4, 5, 6
),

