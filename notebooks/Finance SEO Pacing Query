      (cur.site_abandon_rate / NULLIF(prev.site_abandon_rate, 0)) - 1 AS site_abandon_rate,
      (cur.site_abandon_calls / NULLIF(prev.site_abandon_calls, 0)) - 1 AS site_abandon_calls,
      (cur.site_net_calls / NULLIF(prev.site_net_calls, 0)) - 1 AS site_net_calls,
      (cur.site_conversion_rate / NULLIF(prev.site_conversion_rate, 0)) - 1 AS site_conversion_rate,
      (cur.site_phone_orders / NULLIF(prev.site_phone_orders, 0)) - 1 AS site_phone_orders,
      (cur.total_queue_calls / NULLIF(prev.total_queue_calls, 0)) - 1 AS total_queue_calls,
      (cur.total_abandon_rate / NULLIF(prev.total_abandon_rate, 0)) - 1 AS total_abandon_rate,
      (cur.total_abandon_calls / NULLIF(prev.total_abandon_calls, 0)) - 1 AS total_abandon_calls,
      (cur.total_net_calls / NULLIF(prev.total_net_calls, 0)) - 1 AS total_net_calls,
      (cur.total_net_conversion / NULLIF(prev.total_net_conversion, 0)) - 1 AS total_net_conversion,
      (cur.phone_orders / NULLIF(prev.phone_orders, 0)) - 1 AS phone_orders,
      (cur.cart_rr / NULLIF(prev.cart_rr, 0)) - 1 AS cart_rr,
      (cur.cart_entries / NULLIF(prev.cart_entries, 0)) - 1 AS cart_entries,
      (cur.cart_conversion_rate / NULLIF(prev.cart_conversion_rate, 0)) - 1 AS cart_conversion_rate,
      (cur.cart_orders / NULLIF(prev.cart_orders, 0)) - 1 AS cart_orders,
      (cur.total_orders / NULLIF(prev.total_orders, 0)) - 1 AS total_orders,
      (cur.phone_vc / NULLIF(prev.phone_vc, 0)) - 1 AS phone_vc,
      (cur.cart_vc / NULLIF(prev.cart_vc, 0)) - 1 AS cart_vc,
      (cur.total_vc / NULLIF(prev.total_vc, 0)) - 1 AS total_vc,
      (cur.interaction_yield / NULLIF(prev.interaction_yield, 0)) - 1 AS interaction_yield,
      (cur.phone_revenue / NULLIF(prev.phone_revenue, 0)) - 1 AS phone_revenue,
      (cur.cart_revenue / NULLIF(prev.cart_revenue, 0)) - 1 AS cart_revenue,
      (cur.phone_gcv_order / NULLIF(prev.phone_gcv_order, 0)) - 1 AS phone_gcv_order,
      (cur.cart_gcv_order / NULLIF(prev.cart_gcv_order, 0)) - 1 AS cart_gcv_order,
      (cur.core_revenue / NULLIF(prev.core_revenue, 0)) - 1 AS core_revenue,
      (cur.expansion_revenue / NULLIF(prev.expansion_revenue, 0)) - 1 AS expansion_revenue,
      (cur.core_marketing_cost / NULLIF(prev.core_marketing_cost, 0)) - 1 AS core_marketing_cost,
      (cur.expansion_marketing_cost / NULLIF(prev.expansion_marketing_cost, 0))
        - 1 AS expansion_marketing_cost,
      (cur.scc / NULLIF(prev.scc, 0)) - 1 AS scc,
      (cur.core_cm / NULLIF(prev.core_cm, 0)) - 1 AS core_cm,
      (cur.expansion_cm / NULLIF(prev.expansion_cm, 0)) - 1 AS expansion_cm,
      (cur.total_revenue / NULLIF(prev.total_revenue, 0)) - 1 AS total_revenue,
      (cur.total_marketing_costs / NULLIF(prev.total_marketing_costs, 0))
        - 1 AS total_marketing_costs,
      (cur.total_cm / NULLIF(prev.total_cm, 0)) - 1 AS total_cm,
      (cur.opex / NULLIF(prev.opex, 0)) - 1 AS opex,
      (cur.ebitda / NULLIF(prev.ebitda, 0)) - 1 AS ebitda
    FROM
      cte_base cur
        LEFT JOIN cte_base prev
          ON prev.performance_view = cur.performance_view
          AND prev.MarketingChannel = cur.MarketingChannel
          AND prev.date = add_months(cur.date, -12)
    WHERE
      cur.performance_view IN ('Pacing', 'Plan', 'Internal Plan')
      AND array_contains(:marketing_channel, 'SEO')
      AND NOT array_contains(:marketing_channel, 'AI Search')
  )
  SELECT
    *
  FROM
    cte_base
  UNION ALL
  SELECT
    *
  FROM
    cte_delta_vs_plan
  UNION ALL
  SELECT
    *
  FROM
    cte_delta_vs_internal
  UNION ALL
  SELECT
    *
  FROM
    cte_delta_mom
  UNION ALL
  SELECT
    *
  FROM
    cte_delta_yoy
)
SELECT
  `performance_view` `performance_view`,
  SUM(`sessions`) `sum(sessions)`,
  SUM(`site_rr`) `sum(site_rr)`,
  SUM(`site_conversion_rate`) `sum(site_conversion_rate)`,
  SUM(`phone_vc`) `sum(phone_vc)`,
  SUM(`phone_revenue`) `sum(phone_revenue)`,
  SUM(`cart_rr`) `sum(cart_rr)`,
  SUM(`cart_conversion_rate`) `sum(cart_conversion_rate)`,
  SUM(`cart_vc`) `sum(cart_vc)`,
  SUM(`cart_revenue`) `sum(cart_revenue)`,
  SUM(`total_vc`) `sum(total_vc)`,
  SUM(`total_revenue`) `sum(total_revenue)`,
  GROUPING_ID() `__table_id__`
FROM
  q
WHERE
  `performance_view` IN ('Pacing', 'Plan')
  AND (
    DATE_TRUNC('MONTH', `month`) IN (TO_TIMESTAMP('2026-03-01T00:00:00.000Z'))
    AND DATE_TRUNC('DAY', `date`) IN (TO_TIMESTAMP('2026-03-31T00:00:00.000Z'))
  )
GROUP BY
  GROUPING SETS((`performance_view`), ())
ORDER BY
  `__table_id__` ASC,
  `performance_view` ASC