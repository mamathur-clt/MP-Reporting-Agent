WITH q AS (
  WITH tx_filtered AS (
    SELECT
      CAST(tx.rpt_date AS DATE) AS date,
      tx.month,
      CASE
        WHEN tx.performance_view = 'Final' THEN 'Plan'
        ELSE tx.performance_view
      END AS performance_view,
      CASE
        WHEN
          CAST(tx.rpt_date AS DATE) < '2026-01-01'
          AND tx.MarketingChannel = 'Organic'
        THEN
          'SEO'
        ELSE tx.MarketingChannel
      END AS MarketingChannel,
      tx.impressions,
      tx.clicks,
      tx.sessions,
      tx.marketing_costs,
      tx.serp_queue_calls,
      tx.serp_gross_calls,
      tx.serp_abandon_calls,
      tx.serp_net_calls,
      tx.serp_orders,
      tx.site_queue_calls,
      tx.site_gross_calls,
      tx.site_abandon_calls,
      tx.site_net_calls,
      tx.site_phone_orders,
      tx.total_queue_calls,
      tx.total_abandon_calls,
      tx.total_net_calls,
      tx.phone_orders,
      tx.cart_entries,
      tx.cart_orders,
      tx.total_orders,
      tx.phone_revenue,
      tx.cart_revenue,
      tx.revenue,
      tx.sales_center_cost,
      tx.opex
    FROM
      energy_prod.energy.rpt_texas_daily_pacing tx
    WHERE
      tx.performance_view IN ('Pacing', 'Final', 'Internal Plan')
      AND CAST(tx.rpt_date AS DATE) >= '2025-01-01'
      AND array_contains(
        :marketing_channel,
        CASE
          WHEN
            CAST(tx.rpt_date AS DATE) < '2026-01-01'
            AND tx.MarketingChannel = 'Organic'
          THEN
            'SEO'
          ELSE tx.MarketingChannel
        END
      )
  ),
  agg AS (
    SELECT
      date,
      month,
      performance_view,
      SUM(
        CASE
          WHEN MarketingChannel IN ('Paid Search', 'PMAX', 'Social') THEN impressions
          ELSE 0
        END
      ) AS impressions_paid,
      SUM(
        CASE
          WHEN MarketingChannel IN ('Paid Search', 'PMAX', 'Social') THEN clicks
          ELSE 0
        END
      ) AS clicks_paid,
      SUM(clicks) AS clicks_total,
      SUM(sessions) AS sessions,
      SUM(
        CASE
          WHEN MarketingChannel IN ('PMAX', 'Paid Search', 'Social') THEN clicks
          ELSE 0
        END
      )
        + SUM(
          CASE
            WHEN MarketingChannel NOT IN ('PMAX', 'Paid Search', 'Social') THEN sessions
            ELSE 0
          END
        ) AS interactions,
      SUM(
        CASE
          WHEN MarketingChannel <> 'Affiliate' THEN marketing_costs
          ELSE 0
        END
      ) AS marketing_costs_non_affiliate,
      SUM(serp_queue_calls) AS serp_queue_calls,
      SUM(serp_gross_calls) AS serp_gross_calls,
      SUM(serp_abandon_calls) AS serp_abandon_calls,
      SUM(serp_net_calls) AS serp_net_calls,
      SUM(serp_orders) AS serp_orders,
      SUM(site_queue_calls) AS site_queue_calls,
      SUM(site_gross_calls) AS site_gross_calls,
      SUM(site_abandon_calls) AS site_abandon_calls,
      SUM(site_net_calls) AS site_net_calls,
      SUM(site_phone_orders) AS site_phone_orders,
      SUM(total_queue_calls) AS total_queue_calls,
      SUM(total_abandon_calls) AS total_abandon_calls,
      SUM(total_net_calls) AS total_net_calls,
      SUM(phone_orders) AS phone_orders,
      SUM(cart_entries) AS cart_entries,
      SUM(cart_orders) AS cart_orders,
      SUM(total_orders) AS total_orders,
      SUM(phone_revenue) AS phone_revenue,
      SUM(cart_revenue) AS cart_revenue,
      SUM(
        CASE
          WHEN
            MarketingChannel IN (
              'Paid Search',
              'PMAX',
              'Organic',
              'Direct',
              'Other',
              'Internal',
              'Outbound',
              'Referral'
            )
          THEN
            revenue
          ELSE 0
        END
      ) AS core_revenue,
      SUM(
        CASE
          WHEN MarketingChannel IN ('Social', 'Display', 'Affiliate', 'SMS', 'Email') THEN revenue
          ELSE 0
        END
      ) AS expansion_revenue,
      SUM(
        CASE
          WHEN
            MarketingChannel IN (
              'Paid Search',
              'PMAX',
              'Organic',
              'Direct',
              'Other',
              'Outbound',
              'Cross Sell',
              'Referral'
            )
          THEN
            marketing_costs
          ELSE 0
        END
      ) AS core_marketing_cost,
      SUM(
        CASE
          WHEN
            MarketingChannel IN ('Social', 'Display', 'Affiliate', 'SMS', 'Email')
          THEN
            marketing_costs
          ELSE 0
        END
      ) AS expansion_marketing_cost,
      COALESCE(SUM(sales_center_cost), 0) AS scc,
      SUM(
        CASE
          WHEN
            MarketingChannel IN (
              'Paid Search',
              'PMAX',
              'Organic',
              'Direct',
              'Other',
              'Internal',
              'Outbound',
              'Referral'
            )
          THEN
            revenue
          ELSE 0
        END
      )
        - SUM(
          CASE
            WHEN
              MarketingChannel IN (
                'Paid Search',
                'PMAX',
                'Organic',
                'Direct',
                'Other',
                'Internal',
                'Outbound',
                'Referral'
              )
            THEN
              marketing_costs
            ELSE 0
          END
        ) AS core_cm,
      SUM(
        CASE
          WHEN MarketingChannel IN ('Social', 'Display', 'Affiliate', 'SMS', 'Email') THEN revenue
          ELSE 0
        END
      )
        - SUM(
          CASE
            WHEN
              MarketingChannel IN ('Social', 'Display', 'Affiliate', 'SMS', 'Email')
            THEN
              marketing_costs
            ELSE 0
          END
        ) AS expansion_cm,
      SUM(revenue) AS total_revenue,
      SUM(marketing_costs) AS total_marketing_costs,
      SUM(revenue) - SUM(marketing_costs) - COALESCE(SUM(sales_center_cost), 0) AS total_cm,
      SUM(opex) AS opex,
      (SUM(revenue) - SUM(marketing_costs) - COALESCE(SUM(sales_center_cost), 0))
        - SUM(opex) AS ebitda,
      SUM(
        CASE
          WHEN MarketingChannel IN ('PMAX', 'Paid Search', 'Social') THEN clicks
          ELSE sessions
        END
      ) AS interaction_yield_denom
    FROM
      tx_filtered
    GROUP BY
      1,
      2,
      3
  ),
  cte_base AS (
    SELECT
      date,
      month,
      performance_view,
      CASE
        WHEN array_contains(:marketing_channel, 'SEO') THEN 'SEO'
        WHEN array_contains(:marketing_channel, 'AI Search') THEN 'AI Search'
        ELSE 'Selected Channels'
      END AS MarketingChannel,
      impressions_paid AS impressions,
      clicks_paid AS clicks,
      sessions,
      interactions,
      clicks_paid * 1.0 / NULLIF(impressions_paid, 0) AS ctr,
      marketing_costs_non_affiliate * 1.0 / NULLIF(clicks_total, 0) AS cpc,
      serp_queue_calls * 1.0 / NULLIF(clicks_total, 0) AS serp_rr,
      serp_queue_calls * 1.0 / NULLIF(serp_gross_calls, 0) AS serp_q2g,
      serp_queue_calls,
      serp_abandon_calls * 1.0 / NULLIF(serp_queue_calls, 0) AS serp_abandon_rate,
      serp_abandon_calls,
      serp_net_calls,
      serp_orders * 1.0 / NULLIF(serp_queue_calls, 0) AS serp_conversion_rate,
      serp_orders,
      site_queue_calls * 1.0 / NULLIF(sessions, 0) AS site_rr,
      site_queue_calls * 1.0 / NULLIF(site_gross_calls, 0) AS site_q2g,
      site_queue_calls,
      site_abandon_calls * 1.0 / NULLIF(site_queue_calls, 0) AS site_abandon_rate,
      site_abandon_calls,
      site_net_calls,
      site_phone_orders * 1.0 / NULLIF(site_queue_calls, 0) AS site_conversion_rate,
      site_phone_orders,
      total_queue_calls,
      total_abandon_calls * 1.0 / NULLIF(total_queue_calls, 0) AS total_abandon_rate,
      total_abandon_calls,
      total_net_calls,
      phone_orders * 1.0 / NULLIF(total_net_calls, 0) AS total_net_conversion,
      phone_orders,
      cart_entries * 1.0 / NULLIF(sessions, 0) AS cart_rr,
      cart_entries,
      cart_orders * 1.0 / NULLIF(cart_entries, 0) AS cart_conversion_rate,
      cart_orders,
      total_orders,
      site_phone_orders * 1.0 / NULLIF(sessions, 0) AS phone_vc,
      cart_orders * 1.0 / NULLIF(sessions, 0) AS cart_vc,
      (total_orders - serp_orders) * 1.0 / NULLIF(sessions, 0) AS total_vc,
      total_orders * 1.0 / NULLIF(interaction_yield_denom, 0) AS interaction_yield,
      phone_revenue,
      cart_revenue,
      phone_revenue * 1.0 / NULLIF(phone_orders, 0) AS phone_gcv_order,
      cart_revenue * 1.0 / NULLIF(cart_orders, 0) AS cart_gcv_order,
      core_revenue,
      expansion_revenue,
      core_marketing_cost,
      expansion_marketing_cost,
      scc,
      core_cm,
      expansion_cm,
      total_revenue,
      total_marketing_costs,
      total_cm,
      opex,
      ebitda
    FROM
      agg
  ),
