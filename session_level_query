-- ===== 2.10 Review Page Clicks =====
, review_page AS (
  SELECT cartsession_id_review,
         MAX(clicked_review_page_cta) AS clicked_review_page_cta
  FROM (
    -- Formsubmitted event
    SELECT cs.cart_session_id AS cartsession_id_review,
           MAX(CASE WHEN fc.cartcontext.pagereferrer ILIKE '%review%' THEN 1 END) AS clicked_review_page_cta
    FROM lakehouse_production.energy.event_redventures_cart_formsubmitted fc
    JOIN (
      SELECT cart_instance_id, MAX(cart_session_id) AS cart_session_id
      FROM lakehouse_production.energy.event_redventures_cart_cartstarted
      GROUP BY cart_instance_id
    ) cs ON fc.cart_instance_id = cs.cart_instance_id
    CROSS JOIN cte_variables var
    WHERE fc._date > var.start_date
    GROUP BY cs.cart_session_id

    UNION ALL

    -- Usertracking formcontinued event
    SELECT cs.cart_session_id AS cartsession_id_review,
           MAX(CASE WHEN fc3.step_context_step_name = 'review' THEN 1 END) AS clicked_review_page_cta
    FROM lakehouse_production.energy.event_redventures_usertracking_formcontinued fc3
    JOIN (
      SELECT cart_instance_id, MAX(cart_session_id) AS cart_session_id
      FROM lakehouse_production.energy.event_redventures_cart_cartstarted
      GROUP BY cart_instance_id
    ) cs ON cs.cart_instance_id = fc3.correlationId
    CROSS JOIN cte_variables var
    WHERE fc3._date > var.start_date
    GROUP BY cs.cart_session_id
  ) z
  GROUP BY cartsession_id_review
)





-- ===== 2.11 Finalized Cart Aggregate =====
, cart_session_agg AS (
  SELECT
    s.webcontext_session_id,

    -- Overall Cart Entries
    COUNT(DISTINCT c.cartsession_id) AS cart_entries,
    MAX(CASE WHEN c.cartsession_id IS NOT NULL THEN 1 ELSE 0 END) AS has_cart,

    -- ROG Cart Entries
    COUNT(DISTINCT CASE WHEN COALESCE(ri.rogs_ind, 0) = 1 THEN c.cartsession_id END) AS rog_cart_entries,
    CASE WHEN COUNT(DISTINCT CASE WHEN COALESCE(ri.rogs_ind, 0) = 1 THEN c.cartsession_id END) >= 1 THEN 1 ELSE 0 END AS has_rog_cart,
    MAX(CASE WHEN COALESCE(ri.rogs_ind, 0) = 1 THEN 1 ELSE 0 END) AS entered_through_rog,


    -- Grid Cart Entries
    COUNT(DISTINCT CASE WHEN COALESCE(ri.rogs_ind, 0) = 0 THEN c.cartsession_id END) AS grid_cart_entries,
    CASE WHEN COUNT(DISTINCT CASE WHEN COALESCE(ri.rogs_ind, 0) = 0 THEN c.cartsession_id END) >= 1 THEN 1 ELSE 0 END AS has_grid_cart,

    -- Types of Cart Entries 
      MAX(c.first_partner_name) AS first_partner_name,
      MAX(c.first_product_name) AS first_product_name,
      MAX(c.last_partner_name) AS last_partner_name,
      MAX(c.last_product_name) AS last_product_name,
    -- Cart Info Submit Metrics
    MAX(sc.page_1_completion) AS cart_page1_done,
    MAX(sc.customer_info_completion) AS cart_customer_info_done,
    MAX(sc.ssn_completion) AS cart_ssn_done,
    MAX(rev.clicked_review_page_cta) AS cart_review_cta_click,


    -- Credit Run Info
    MAX(fcr.cart_credit_runs) AS cart_credit_runs,
    MAX(fcr.cart_max_credit_score) AS cart_max_credit_score,
    MAX(fcr.cart_ucc_pass_credit) AS cart_ucc_pass,
    MAX(fcr.cart_providers_passed_credit) AS cart_providers_passed,
    MAX(fcr.cart_providers_failed_credit) AS cart_providers_failed,
    MAX(CASE WHEN fcr.first_run_provider_pass = 'pass' THEN 1 ELSE 0 END) AS cart_provider_pass,
    MAX(credit_fail) as cart_credit_fail, 
    MAX(fcr.first_run_credit_score) AS first_run_credit_score,
    MAX(fcr.first_run_provider_name) AS first_run_provider_name,


    -- Partner Qual & Volt 
    MAX(qf.qual_fail) AS cart_qual_fail,
    MAX(v.volt_fail) AS cart_volt_fail,
    MAX(v.negative_list_fail_count) AS cart_negative_list_fail_cnt,
    MAX(v.seon_fail_count) AS cart_seon_fail_cnt,

    -- Pivot Interaction 
    MAX(pcf.pivot_clicked) AS cart_pivot_clicked,
    MAX(CASE WHEN ptt.integration_context_client_session_id IS NOT NULL THEN 1 ELSE 0 END) AS cart_pivot_triggered,

    -- Cart Order Metrics
    SUM(c.cart_order) AS cart_order,
    COUNT(DISTINCT CASE WHEN c.cart_order = 1 THEN c.cartsession_id END) AS cart_order2,
    SUM(c.order_gcv) AS cart_gcv,
    MAX(c.order_term_length) AS order_term_length,
    MAX(c.order_partner_name) AS order_partner_name,
    MAX(c.order_product_name) AS order_product_name


  FROM base_sessions s
  LEFT JOIN cartsession_id_base c ON c.websession_id = s.webcontext_session_id
  LEFT JOIN pivot_click_final pcf ON pcf.cart_session_id = c.cartsession_id
  LEFT JOIN cart_final_credit_run fcr ON fcr.client_session_id = c.cartsession_id
  LEFT JOIN rogs_indicator ri ON ri.session_id = s.webcontext_session_id
  LEFT JOIN step_completions sc ON sc.cartsession_id_completions = c.cartsession_id
  LEFT JOIN qual_final qf ON qf.client_session_id = c.cartsession_id
  LEFT JOIN volt_fail  v  ON v.client_session_id  = c.cartsession_id
  LEFT JOIN pivot_triggers_two_alt ptt ON ptt.integration_context_client_session_id = c.cartsession_id
  LEFT JOIN review_page rev ON rev.cartsession_id_review = c.cartsession_id
  GROUP BY s.webcontext_session_id
)



-- =====================================================
-- ==============  3. Phone Funnel Section  =============
-- =====================================================
, call_orders AS (
 SELECT o.call_id,
   max(o.mover_switcher) order_mover_switcher,
   SUM(o.predicted_activation_rate*o.undiscounted_gcv) est_gcv,
   MAX(product_name) product_name,
   MAX(partner_name) partner_name,
   MAX(o.term) term_length,
   count(distinct o.order_id) AS phone_order
 FROM energy_prod.energy.v_orders o
 CROSS JOIN cte_variables var
 WHERE o.order_date_est BETWEEN var.start_date AND var.end_date
   --AND o.tenant_id IN ('ffc8ff8a-1975-4ec4-8d59-900718adb53d', '4b27d1c6-e19e-4cc0-add3-a44b9b4a4023')
   AND o.order_type = 'Phone'
 GROUP BY o.call_id
)


, phones_call_id_base AS (
 SELECT c.call_id
 , c.web_session_id
 , c.mover_switcher call_mover_switcher
 , c.talk_time_minutes
 , c.ib_gross_ind
 , c.ib_queue_ind
 , c.abandon_ind
 , c.ibs_net_ind
 , c.ivr_profile_name
 , c.spanish_ind
 , c.call_lease
 FROM energy_prod.energy.v_calls c
 CROSS JOIN cte_variables var
 WHERE c.call_date_est BETWEEN var.start_date AND var.end_date
   and c.web_session_id is not null
   --AND c.tenant_id IN ('ffc8ff8a-1975-4ec4-8d59-900718adb53d', '4b27d1c6-e19e-4cc0-add3-a44b9b4a4023')
)


-- Session level aggregation for phone funnel
, phone_session_agg AS (
 SELECT
     s.webcontext_session_id
   , MAX(NVL(p.call_mover_switcher, co.order_mover_switcher)) AS call_mover_switcher
   , COUNT(DISTINCT p.call_id)                                 AS call_count
   , MAX(CASE WHEN p.call_id IS NOT NULL THEN 1 ELSE 0 END)    AS has_call
   , COUNT(DISTINCT CASE WHEN p.ib_gross_ind > 0 THEN p.call_id END) as gross_calls
   , COUNT(DISTINCT CASE WHEN p.ib_queue_ind > 0 THEN p.call_id END) AS queue_calls
   , COUNT(DISTINCT CASE WHEN p.ib_queue_ind > 0 AND UPPER(p.call_lease) LIKE '%FUSE-PERMA-GRID%'   THEN p.call_id END) AS queue_calls_grid
   , COUNT(DISTINCT CASE WHEN p.ib_queue_ind > 0 AND UPPER(p.call_lease) LIKE '%FUSE-PERMA-BANNER%' THEN p.call_id END) AS queue_calls_homepage
   , COUNT(DISTINCT CASE WHEN p.ibs_net_ind > 0 THEN p.call_id END) AS net_calls
   , AVG(p.talk_time_minutes)                                  AS avg_talk_time
   , MAX(p.spanish_ind)                                        AS spanish_call
   , SUM(co.phone_order)                                       AS phone_order
   , SUM(co.est_gcv)                                           AS phone_est_gcv
   , MAX(co.term_length)                                       AS phone_term_length
   -- aggregate call_lease to avoid dup rows
   , sort_array(collect_set(upper(p.call_lease)))              AS call_leases        -- array
   , concat_ws(', ', sort_array(collect_set(upper(p.call_lease)))) AS call_lease_list -- readable string
 FROM base_sessions s
 LEFT JOIN phones_call_id_base p ON p.web_session_id = s.webcontext_session_id
 LEFT JOIN call_orders        co ON co.call_id       = p.call_id
 GROUP BY s.webcontext_session_id
),

/* ============================================================
   4) Initiative Identifiers
   ============================================================ */
lp_jo AS (
  SELECT DISTINCT
    d.sessionId,
    CASE
      WHEN CAST(d.isHoldout AS STRING) = 'true' THEN 'Holdout'
      WHEN COALESCE(d.isHoldout, false) = false
           AND dd.explore_exploit_holdout = 'intuitive_explore'
        THEN 'FMP'
      WHEN COALESCE(d.isHoldout, false) = false
           AND dd.explore_exploit_holdout IN ('explore', 'exploit')
        THEN 'Model'
      ELSE 'Model'
    END AS lp_experience
  FROM lakehouse_production.energy.dapi_decisions d
  LEFT JOIN energy_prod.data_science.dapi_decision_explore_exploit_classification dd
    ON dd._id = d._id
  WHERE d.agentId = '3313'
    AND (d.result IN ('SUCCESS', 'FAILURE') OR d.result IS NULL)
),

grid_jo AS (
  SELECT DISTINCT
    d.sessionId,
    CASE
      WHEN CAST(d.isHoldout AS STRING) = 'true' THEN 'Holdout'
      ELSE 'Model'
    END AS grid_isHoldout
  FROM lakehouse_production.energy.dapi_decisions d
  WHERE d.agentId IN ('3378', '3401')
    AND (
      d.result IN ('SUCCESS', 'FAILURE')
      OR d.result IS NULL
      OR (
        d.result = 'ERROR'
        AND decision_provided_date BETWEEN '2026-02-13' AND '2026-02-18'
      )
    )
),

all_session_ids AS (
  SELECT sessionId FROM lp_jo
  UNION
  SELECT sessionId FROM grid_jo
),


initiative_master AS (
  SELECT
    s.sessionId,
    CASE WHEN lp.lp_experience = 'FMP' THEN 1 ELSE 0 END AS is_fmp,

    CASE
      WHEN lp.sessionId IS NOT NULL AND grid.sessionId IS NULL THEN 1
      ELSE 0
    END AS is_lp,

    CASE
      WHEN lp.sessionId IS NULL AND grid.sessionId IS NOT NULL THEN 1
      ELSE 0
    END AS is_grid,

    CASE
      WHEN lp.sessionId IS NOT NULL AND grid.sessionId IS NOT NULL THEN 1
      ELSE 0
    END AS grid_lp,

    lp.lp_experience,

    CASE
      WHEN lp.lp_experience = 'Holdout' THEN 'Holdout'
      WHEN grid.grid_isHoldout = 'Holdout' THEN 'Holdout'
      ELSE 'Model'
    END AS isHoldout

  FROM all_session_ids s
  LEFT JOIN lp_jo lp
    ON s.sessionId = lp.sessionId
  LEFT JOIN grid_jo grid
    ON s.sessionId = grid.sessionId
  WHERE NOT (
    lp.lp_experience IS NOT NULL
    AND grid.grid_isHoldout IS NOT NULL
    AND lp.lp_experience = 'Holdout'
    AND grid.grid_isHoldout <> 'Holdout'
  )
  AND NOT (
    lp.lp_experience IS NOT NULL
    AND grid.grid_isHoldout IS NOT NULL
    AND lp.lp_experience <> 'Holdout'
    AND grid.grid_isHoldout = 'Holdout'
  )
), 

final AS (
  SELECT
    -- ===== Session Level Information (Mix Drivers) =====
    1 as session, 
    bs.webcontext_session_id,
    bs.session_start_date_est,
    bs.website,
    bs.device_type,
    bs.marketing_channel,
    bs.mover_switcher, 
    bs.landing_page_type,

    -- ===== Initiative / experiment identifiers =====
    m.is_fmp,
    m.is_lp,
    m.is_grid,
    m.grid_lp,
    m.lp_experience,
    m.isHoldout,

    -- ===== Funnel Flags =====
    -- CART 
    bs.zip_entry, 
    c.has_cart,  
    c.cart_order,
    c.cart_page1_done,          -- Contact Info + Address Step Completed
    c.cart_customer_info_done,  -- Customer Info Form Submitted
    c.cart_ssn_done,            -- SSN / Credit Step Completed,
    c.cart_gcv, 

    -- PHONES 
    CASE WHEN p.gross_calls >= 1 THEN 1 ELSE 0 END as gross_call,
    CASE WHEN p.queue_calls >= 1 THEN 1 ELSE 0 END AS queue_call,
    p.phone_order,   
    p.phone_est_gcv,          

    -- === Partnership Information === 
    c.first_partner_name, 
    c.order_partner_name, 

    -- ===== Customer Quality Identifiers ==
    c.cart_volt_fail,       
    c.cart_credit_fail,          
    c.cart_provider_pass,     
    c.cart_qual_fail,           
    c.cart_max_credit_score,
    c.first_run_credit_score,
    c.first_run_provider_name
    
  FROM base_sessions bs
  LEFT JOIN cart_session_agg c ON bs.webcontext_session_id = c.webcontext_session_id
  LEFT JOIN phone_session_agg p ON bs.webcontext_session_id = p.webcontext_session_id
  LEFT JOIN initiative_master m ON bs.webcontext_session_id = m.sessionId
)
SELECT * FROM final 

